{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Standard Line Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project",
    "network",
    "projectStages",
    "processFlow",
    "commSignals",
    "alarmBands",
    "stations"
  ],
  "properties": {
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "name",
        "version",
        "tiaVersion",
        "lineControlStation"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "tiaVersion": {
          "type": "string",
          "minLength": 1
        },
        "includeHmi": {
          "type": "boolean"
        },
        "lineControlStation": {
          "type": "string",
          "pattern": "^Station\\d{2}$"
        }
      }
    },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subnetName",
        "subnetTypeIdentifier",
        "subnetMask",
        "useRouter",
        "ipProtocolSelection"
      ],
      "properties": {
        "subnetName": {
          "type": "string",
          "minLength": 1
        },
        "subnetTypeIdentifier": {
          "type": "string",
          "minLength": 1
        },
        "subnetMask": {
          "type": "string",
          "pattern": "^(?:\\d{1,3}\\.){3}\\d{1,3}$"
        },
        "useRouter": {
          "type": "boolean"
        },
        "routerAddress": {
          "type": "string",
          "pattern": "^$|^(?:\\d{1,3}\\.){3}\\d{1,3}$"
        },
        "ipProtocolSelection": {
          "type": "string",
          "enum": [
            "None",
            "Project",
            "Dhcp",
            "UserProgram",
            "OtherPath",
            "ViaIoController"
          ]
        }
      }
    },
    "projectStages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "deliverable"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "minimum": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "deliverable": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "processFlow": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "from",
          "to",
          "description"
        ],
        "properties": {
          "from": {
            "type": "string",
            "pattern": "^Station\\d{2}$"
          },
          "to": {
            "type": "string",
            "pattern": "^Station\\d{2}$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "commSignals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "direction",
          "description"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "direction": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "alarmBands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "station",
          "start",
          "end"
        ],
        "properties": {
          "station": {
            "type": "string",
            "minLength": 1
          },
          "start": {
            "type": "integer",
            "minimum": 0
          },
          "end": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "stations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "key",
          "stationNumber",
          "displayName",
          "role",
          "folderName",
          "deviceName",
          "deviceItemName",
          "cpuTypeIdentifier",
          "hasLineControl",
          "deviceTemplates",
          "network",
          "io"
        ],
        "properties": {
          "key": {
            "type": "string",
            "pattern": "^Station\\d{2}$"
          },
          "stationNumber": {
            "type": "integer",
            "minimum": 1
          },
          "displayName": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "minLength": 1
          },
          "folderName": {
            "type": "string",
            "minLength": 1
          },
          "deviceName": {
            "type": "string",
            "minLength": 1
          },
          "deviceItemName": {
            "type": "string",
            "minLength": 1
          },
          "cpuTypeIdentifier": {
            "type": "string",
            "minLength": 1
          },
          "hasLineControl": {
            "type": "boolean"
          },
          "deviceTemplates": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "network": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "ipAddress",
              "pnDeviceName",
              "interfaceOperatingMode",
              "autoGeneratePnDeviceName"
            ],
            "properties": {
              "ipAddress": {
                "type": "string",
                "pattern": "^(?:\\d{1,3}\\.){3}\\d{1,3}$"
              },
              "pnDeviceName": {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9-]{0,62}$"
              },
              "interfaceOperatingMode": {
                "type": "string",
                "pattern": "^(None|IoDevice|IoController|IoDeviceAndIoController|IoDevice, IoController|IoController, IoDevice)$"
              },
              "autoGeneratePnDeviceName": {
                "type": "boolean"
              }
            }
          },
          "io": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "inputs",
              "outputs"
            ],
            "properties": {
              "inputs": {
                "type": "integer",
                "minimum": 0
              },
              "outputs": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        }
      }
    }
  }
}
