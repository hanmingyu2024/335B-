// FC_AutoSeq - Station 02 processing sequence

IF NOT DB_Station.RunCmd THEN
    DB_Station.CycleActive := FALSE;
    DB_Station.OutClampValve := FALSE;
    DB_Station.OutTableValve := FALSE;
    DB_Station.OutHeadValve := FALSE;
    RETURN;
END_IF;

IF DB_Station.CycleActive AND (DB_Station.Step <> 0) THEN
    IF DB_Station.Step <> DB_Station.ActiveStepLast THEN
        DB_Station.ActiveStepLast := DB_Station.Step;
        DB_Station.ActiveStepWatchdog := 0;
    ELSIF DB_Station.ActiveStepWatchdog < DB_Station.ActiveStepLimit THEN
        DB_Station.ActiveStepWatchdog := DB_Station.ActiveStepWatchdog + 1;
    ELSE
        DB_Station.FaultActuator := TRUE;
        DB_Station.FaultActive := TRUE;
        DB_Station.RunCmd := FALSE;
        DB_Station.CycleActive := FALSE;
        RETURN;
    END_IF;
ELSE
    DB_Station.ActiveStepLast := DB_Station.Step;
    DB_Station.ActiveStepWatchdog := 0;
END_IF;

CASE DB_Station.Step OF
    0:
        DB_Station.CycleActive := FALSE;
        DB_Station.StationDone := FALSE;
        IF DB_Comm.PartReceived AND DB_Station.InPartAtProc AND DB_Station.InHeadUp AND DB_Station.InTableBwd THEN
            DB_Station.Step := 10;
        END_IF;
    10:
        DB_Station.CycleActive := TRUE;
        DB_Station.OutTableValve := TRUE;
        IF DB_Station.InTableFwd THEN
            DB_Station.Step := 20;
        END_IF;
    20:
        DB_Station.OutClampValve := TRUE;
        IF DB_Station.InClampOk THEN
            DB_Station.Step := 30;
        END_IF;
    30:
        DB_Station.OutHeadValve := TRUE;
        IF DB_Station.InHeadDown THEN
            DB_Station.Step := 40;
        END_IF;
    40:
        DB_Station.OutHeadValve := FALSE;
        IF DB_Station.InHeadUp THEN
            DB_Station.Step := 50;
        END_IF;
    50:
        DB_Station.OutClampValve := FALSE;
        DB_Station.OutTableValve := FALSE;
        IF DB_Station.InTableBwd THEN
            DB_Station.Step := 60;
        END_IF;
    60:
        DB_Station.CycleActive := FALSE;
        DB_Station.StationDone := TRUE;
        DB_Comm.ProcessDone := TRUE;
        DB_Comm.PartReady := TRUE;
        DB_Comm.ReqOut := TRUE;
        IF DB_Comm.TakeDone THEN
            DB_Comm.ReqOut := FALSE;
            DB_Comm.PartReady := FALSE;
            DB_Comm.ProcessDone := FALSE;
            DB_Comm.PartReceived := FALSE;
            DB_Station.StationDone := FALSE;
            DB_Station.Step := 0;
        ELSIF NOT DB_Station.RunCmd THEN
            DB_Station.Step := 0;
        END_IF;
ELSE
    DB_Station.Step := 0;
END_CASE;
