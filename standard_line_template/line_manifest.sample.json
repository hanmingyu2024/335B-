  "projectStages": [
    {
      "id": 1,
      "name": "IO Mapping",
      "deliverable": "I/O list and hardware address allocation"
    },
    {
      "id": 2,
      "name": "Process Flow",
      "deliverable": "Process sequence and inter-station handshakes"
    },
    {
      "id": 3,
      "name": "Device Modeling",
      "deliverable": "CPU model and station device abstraction"
    },
    {
      "id": 4,
      "name": "Scaffold Build",
      "deliverable": "Standard directory and source skeleton"
    },
    {
      "id": 5,
      "name": "Programming",
      "deliverable": "Station control, device and communication logic"
    },
    {
      "id": 6,
      "name": "Commissioning",
      "deliverable": "Compile logs and debug records"
    },
    {
      "id": 7,
      "name": "Optimization",
      "deliverable": "Template hardening and version iteration"
    }
  ],
  "processFlow": [
    {
      "from": "Station01",
      "to": "Station03",
      "description": "Supply station hands off part to transfer station"
    },
    {
      "from": "Station03",
      "to": "Station02",
      "description": "Transfer station places part to process station"
    },
    {
      "from": "Station02",
      "to": "Station03",
      "description": "Process station returns finished part to transfer station"
    },
    {
      "from": "Station03",
      "to": "Station04",
      "description": "Transfer station places part to assembly station"
    },
    {
      "from": "Station04",
      "to": "Station03",
      "description": "Assembly station returns assembled part to transfer station"
    },
    {
      "from": "Station03",
      "to": "Station05",
      "description": "Transfer station sends part to sorting station"
    }
  ],
